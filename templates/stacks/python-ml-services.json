{
  "name": "Python ML Services Development",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter",
        "ms-python.pylint",
        "ms-python.flake8",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "charliermarsh.ruff",
        "ckolkman.vscode-postgres",
        "ms-vscode.vscode-docker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/miniconda3/bin/python",
        "python.terminal.activateEnvironment": true,
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true,
        "python.formatting.provider": "black",
        "python.linting.flake8Enabled": true,
        "jupyter.askForKernelRestart": false,
        "jupyter.alwaysTrustNotebooks": true,
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit"
        },
        "files.associations": {
          "*.py": "python",
          "*.ipynb": "jupyter",
          "*.yaml": "yaml",
          "*.yml": "yaml"
        }
      }
    }
  },

  "forwardPorts": [8888, 8000, 6006, 5432, 6379, 8001],
  "portsAttributes": {
    "8888": {
      "label": "Jupyter Lab",
      "onAutoForward": "notify"
    },
    "8000": {
      "label": "Python API Server",
      "onAutoForward": "silent"
    },
    "6006": {
      "label": "TensorBoard",
      "onAutoForward": "silent"
    },
    "5432": {
      "label": "PostgreSQL + pgvector",
      "onAutoForward": "silent"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "silent"
    },
    "8001": {
      "label": "Redis Insights",
      "onAutoForward": "silent"
    }
  },

  "features": {
    "ghcr.io/visheshd/claude-devcontainer/claude-mcp:1": {
      "servers": "serena,context7,langchain-tools,vector-db"
    }
  },

  "postCreateCommand": "uv sync || pip install -r requirements.txt || echo 'No requirements found'",

  "containerEnv": {
    "JUPYTER_ENABLE_LAB": "yes",
    "PYTHONPATH": "/workspace"
  }
}
