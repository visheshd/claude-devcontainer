#!/usr/bin/env node

// Standalone worktree command - routes to the appropriate subcommand
import('../src/index.js').then(module => {
  const originalArgv = process.argv;
  const firstArg = originalArgv[2];

  // `wt status` and `wt ls` route to the status subcommand
  if (firstArg === 'status' || firstArg === 'ls') {
    process.argv = ['node', 'wt', 'status', ...originalArgv.slice(3)];
  } else {
    // Default: treat args as feature-name [branch-ref] for worktree creation
    process.argv = ['node', 'wt', 'wt', ...originalArgv.slice(2)];
  }

  if (module.default && typeof module.default === 'function') {
    module.default();
  }
}).catch(error => {
  console.error('Error starting wt command:', error);
  process.exit(1);
});