{
  "name": "Test Rust Tauri",
  "postCreateCommand": "startup.sh",
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/claude-user/.claude,type=bind",
    "source=${localWorkspaceFolder},target=/main-repo,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/.cargo,target=/home/claude-user/.cargo,type=bind"
  ],
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "remoteUser": "claude-user",
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "eamodio.gitlens",
        "github.vscode-pull-request-github",
        "ms-vscode.vscode-json",
        "redhat.vscode-yaml",
        "ms-vsliveshare.vsliveshare",
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb",
        "serayuzgur.crates",
        "tauri-apps.tauri-vscode"
      ],
      "settings": {
        "git.enableSmartCommit": true,
        "git.confirmSync": false,
        "git.autofetch": true,
        "editor.formatOnSave": true,
        "terminal.integrated.defaultProfile.linux": "zsh",
        "files.associations": {
          "*.env.*": "properties"
        },
        "rust-analyzer.checkOnSave.command": "clippy",
        "rust-analyzer.cargo.features": "all"
      }
    }
  },
  "features": {
    "ghcr.io/visheshd/claude-devcontainer/claude-mcp:1": {
      "servers": "serena,context7"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },
  "onCreateCommand": {
    "install-deps": "echo 'Base container ready - stack-specific setup will run next'"
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb"
  },
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/claude-user/.claude"
  },
  "image": "claude-rust-tauri:latest",
  "forwardPorts": [
    1420,
    3000,
    8080
  ],
  "portsAttributes": {
    "1420": {
      "label": "Tauri Dev Server",
      "onAutoForward": "notify"
    }
  }
}